# ============================================
# 智能旅游顾问系统 - 环境变量配置（模板）
# 复制此文件为 .env 并填入真实密钥
# ============================================

# Kimi AI API (Moonshot / 腾讯MaaS)
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://tokenhub.tencentmaas.com/v1

# 高德地图 API Key（获取地址：https://lbs.amap.com/）
AMAP_KEY=your_amap_key_here

# 和风天气 API Key（获取地址：https://dev.qweather.com/）
QWEATHER_API_KEY=your_qweather_key_here
